# =============================================================================
# .env.example — 将此文件复制为 .env 并填写真实凭据
# 复制命令：cp .env.example .env
# =============================================================================

# HuggingFace Token（用于下载 Qwen 模型和数据集）
# 获取地址：https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dashscope API Key（用于 7B/14B 参考模型 API 评测）
# 获取地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
